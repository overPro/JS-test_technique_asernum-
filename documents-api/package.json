{
  "name": "documents-api",
  "version": "1.0.0",
  "description": "API Documents - Gestion fichiers, dossiers, authentification JWT et upload",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node -r tsconfig-paths/register dist/main.js",
    "start:dev": "nodemon --exec ts-node -r tsconfig-paths/register src/main.ts",
    "typeorm": "typeorm-ts-node-esm",
    "migration:generate": "typeorm migration:generate",
    "migration:run": "typeorm migration:run",
    "migration:revert": "typeorm migration:revert"
  },
  "keywords": [
    "nestjs",
    "documents",
    "upload",
    "jwt",
    "cqrs"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@fastify/static": "^6.12.0",
    "@nestjs/bullmq": "^10.0.1",
    "@nestjs/common": "^10.2.10",
    "@nestjs/config": "^3.1.1",
    "@nestjs/core": "^10.2.10",
    "@nestjs/cqrs": "^10.0.1",
    "@nestjs/jwt": "^11.0.1",
    "@nestjs/passport": "^10.0.3",
    "@nestjs/platform-express": "^11.1.13",
    "@nestjs/platform-fastify": "^10.2.10",
    "@nestjs/swagger": "^7.1.13",
    "@nestjs/typeorm": "^10.0.0",
    "bcryptjs": "^2.4.3",
    "bull": "^4.11.4",
    "bullmq": "^5.0.3",
    "class-transformer": "^0.5.1",
    "class-validator": "^0.14.0",
    "fastify": "^4.25.1",
    "joi": "^17.11.0",
    "passport": "^0.7.0",
    "passport-jwt": "^4.0.1",
    "pg": "^8.11.3",
    "redis": "^4.6.11",
    "reflect-metadata": "^0.1.13",
    "rxjs": "^7.8.1",
    "sharp": "^0.33.0",
    "typeorm": "^0.3.17",
    "uuid": "^9.0.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/express": "^4.17.25",
    "@types/node": "^20.10.0",
    "@types/passport-jwt": "^4.0.1",
    "@types/sharp": "^0.32.0",
    "nodemon": "^3.0.2",
    "ts-loader": "^9.5.1",
    "ts-node": "^10.9.1",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.2"
  }
}

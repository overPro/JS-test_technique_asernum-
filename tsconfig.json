{
  "compilerOptions": {
    "module": "commonjs",
    "target": "ES2020",
    "lib": ["ES2020"],
    "outDir": "./dist",
    "rootDir": "./",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true,
    "moduleResolution": "node",
    "allowSyntheticDefaultImports": true,
    "experimentalDecorators": true,
    "emitDecoratorMetadata": true,
    "baseUrl": ".",
    "paths": {
      "@shared/*": ["shared/*"],
      "@documents/*": ["documents-api/src/*"],
      "@sharing/*": ["sharing-api/src/*"],
      "@worker/*": ["processing-worker/src/*"]
    }
  },
  "include": ["documents-api", "sharing-api", "processing-worker", "shared"],
  "exclude": ["node_modules", "dist"]
}
